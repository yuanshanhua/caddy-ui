{
  "name": "caddy-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A pure static SPA for managing Caddy web server via its Admin API",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "i18n:extract": "i18next-cli extract",
    "i18n:status": "i18next-cli status",
    "i18n:ci": "i18next-cli extract --ci",
    "deps:check": "ncu",
    "deps:update": "ncu -u --target minor && pnpm install",
    "deps:update:major": "ncu -u && pnpm install",
    "check": "pnpm lint && pnpm typecheck && pnpm i18n:ci"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-router": "^7.14.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "i18next-cli": "^1.56.9",
    "npm-check-updates": "^22.1.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10"
  }
}